# Client-side environment variables (exposed to browser, must use VITE_ prefix)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SITE_URL=http://localhost:3000

# Server-side environment variables (secure, used by serverless functions)
# Note: No VITE_ prefix - these are NOT exposed to the client
GEMINI_API_KEY=your_gemini_api_key

# E2E Testing (Playwright) - create a test user in Supabase Dashboard first
VITE_TEST_USER_EMAIL=test@playwright.test
VITE_TEST_USER_PASSWORD=your_test_user_password
